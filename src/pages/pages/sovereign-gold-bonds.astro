              <tbody>
                <tr><td><strong>SGB 2016-17 (Series I)</strong></td><td>₹3,119</td><td>₹7,250</td><td>132.5%</td><td>~157.5% (10 yr)</td></tr>
                <tr><td><strong>SGB 2018-19 (Series II)</strong></td><td>₹3,146</td><td>₹7,250</td><td>130.4%</td><td>~150.4% (8 yr)</td></tr>
                <tr><td><strong>SGB 2020-21 (Series V)</strong></td><td>₹4,590</td><td>₹7,250</td><td>58.0%</td><td>~73.0% (6 yr)</td></tr>
