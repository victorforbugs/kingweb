                <tr>
                  <th>Security Type</th>
                  <th>Tenure</th>
                  <th>Current Yield</th>
                  <th>Coupon Rate</th>
                </tr>
              </thead>
              <tbody>
                <tr><td><strong>91-Day Treasury Bill</strong></td><td>3 Months</td><td>6.55%</td><td>Zero Coupon</td></tr>
                <tr><td><strong>182-Day Treasury Bill</strong></td><td>6 Months</td><td>6.65%</td><td>Zero Coupon</td></tr>
