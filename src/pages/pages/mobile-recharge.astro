---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Mobile Recharge Online | TrueCred Loan Expert">

<!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span class="sep"><i class="fas fa-chevron-right"></i></span>
        <a href="/pages/recharge-bills">Recharge &amp; Bills</a>
        <span class="sep"><i class="fas fa-chevron-right"></i></span>
        <span>Mobile Recharge</span>
      </div>
      <h1>Mobile Recharge Online</h1>
      <p class="hero-sub">Recharge any prepaid or postpaid mobile number instantly. All major operators supported — Jio, Airtel, Vi, BSNL &amp; more. Get cashback on every recharge.</p>
      <div class="hero-highlights">
        <div class="highlight-item">
          <i class="fas fa-tower-cell"></i> Operators: All Major
        </div>
        <div class="highlight-item">
          <i class="fas fa-percent"></i> Cashback: Up to 5%
        </div>
        <div class="highlight-item">
          <i class="fas fa-bolt"></i> Processing: Instant
        </div>
      </div>
    </div>
  </section>

  <!-- Page Content -->
  <section class="page-content">
    <div class="container">
      <div class="content-grid">

        <!-- Main Content -->
        <div class="content-main">
          <h2>Recharge Your Mobile in Seconds</h2>
          <p>TrueCred Loan Expert offers the fastest and most convenient way to recharge your prepaid or postpaid mobile number online. Whether you use Jio, Airtel, Vi (Vodafone Idea), or BSNL — simply enter your number, choose a plan, and complete the recharge in under 30 seconds.</p>
          <p>Our platform automatically fetches the latest plans from all operators so you always see the most current offers, including unlimited data packs, talktime plans, and international roaming recharges. Plus, earn cashback and rewards on every successful recharge.</p>

          <!-- Comparison Table -->
          <h3>Popular Prepaid Plans Comparison</h3>
          <div class="table-responsive" style="overflow-x:auto; margin: 24px 0 40px;">
            <table style="width:100%; border-collapse:collapse; min-width:600px;">
              <thead>
                <tr style="background: var(--primary); color: #fff;">
                  <th style="padding: 12px 16px; text-align:left;">Operator</th>
                  <th style="padding: 12px 16px; text-align:left;">Plan</th>
                  <th style="padding: 12px 16px; text-align:center;">Validity</th>
                  <th style="padding: 12px 16px; text-align:center;">Data</th>
                  <th style="padding: 12px 16px; text-align:center;">Price</th>
                </tr>
              </thead>
              <tbody>
                <tr style="border-bottom: 1px solid #e5e7eb;">
                  <td style="padding: 12px 16px; font-weight:600;">Jio</td>
                  <td style="padding: 12px 16px;">Unlimited Calls + Data</td>
                  <td style="padding: 12px 16px; text-align:center;">84 Days</td>
                  <td style="padding: 12px 16px; text-align:center;">2 GB/Day</td>
                  <td style="padding: 12px 16px; text-align:center; font-weight:700; color: var(--primary);">₹799</td>
                </tr>
                <tr style="border-bottom: 1px solid #e5e7eb; background: #f9fafb;">
                  <td style="padding: 12px 16px; font-weight:600;">Airtel</td>
                  <td style="padding: 12px 16px;">Unlimited Calls + Data</td>
                  <td style="padding: 12px 16px; text-align:center;">84 Days</td>
                  <td style="padding: 12px 16px; text-align:center;">2 GB/Day</td>
                  <td style="padding: 12px 16px; text-align:center; font-weight:700; color: var(--primary);">₹839</td>
                </tr>
                <tr style="border-bottom: 1px solid #e5e7eb;">
                  <td style="padding: 12px 16px; font-weight:600;">Vi</td>
                  <td style="padding: 12px 16px;">Unlimited Calls + Data</td>
                  <td style="padding: 12px 16px; text-align:center;">84 Days</td>
                  <td style="padding: 12px 16px; text-align:center;">2 GB/Day</td>
                  <td style="padding: 12px 16px; text-align:center; font-weight:700; color: var(--primary);">₹819</td>
                </tr>
                <tr style="border-bottom: 1px solid #e5e7eb; background: #f9fafb;">
                  <td style="padding: 12px 16px; font-weight:600;">BSNL</td>
                  <td style="padding: 12px 16px;">Unlimited Calls + Data</td>
                  <td style="padding: 12px 16px; text-align:center;">84 Days</td>
                  <td style="padding: 12px 16px; text-align:center;">2 GB/Day</td>
                  <td style="padding: 12px 16px; text-align:center; font-weight:700; color: var(--primary);">₹697</td>
                </tr>
                <tr>
                  <td style="padding: 12px 16px; font-weight:600;">MTNL</td>
                  <td style="padding: 12px 16px;">Unlimited Calls + Data</td>
                  <td style="padding: 12px 16px; text-align:center;">90 Days</td>
                  <td style="padding: 12px 16px; text-align:center;">1.5 GB/Day</td>
                  <td style="padding: 12px 16px; text-align:center; font-weight:700; color: var(--primary);">₹749</td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Benefits -->
          <h2>Why Recharge Through TrueCred?</h2>
          <ul class="feature-list">
            <li><i class="fas fa-check-circle"></i> <strong>All Operators Supported:</strong> Jio, Airtel, Vi (Vodafone Idea), BSNL, and MTNL — prepaid and postpaid</li>
            <li><i class="fas fa-check-circle"></i> <strong>Instant Recharge:</strong> Your recharge is processed within seconds after successful payment</li>
            <li><i class="fas fa-check-circle"></i> <strong>Cashback Rewards:</strong> Earn up to 5% cashback on every recharge, credited to your TrueCred wallet</li>
            <li><i class="fas fa-check-circle"></i> <strong>Latest Plans Auto-Fetched:</strong> We display the most current plans directly from operators so you never miss a deal</li>
            <li><i class="fas fa-check-circle"></i> <strong>Multiple Payment Options:</strong> Pay via UPI, debit card, credit card, net banking, or digital wallets</li>
            <li><i class="fas fa-check-circle"></i> <strong>Recharge History &amp; Reminders:</strong> Track past recharges and set reminders so you never run out of balance</li>
          </ul>

          <!-- How It Works -->
          <h2>How to Recharge Your Mobile</h2>
          <p>Complete your mobile recharge in just 4 simple steps.</p>
          <div class="steps-grid">
            <div class="step-card">
              <div class="step-num">1</div>
              <h4>Enter Mobile Number</h4>
              <p>Type your 10-digit prepaid or postpaid mobile number and select your operator.</p>
            </div>
            <div class="step-card">
              <div class="step-num">2</div>
              <h4>Choose a Plan</h4>
              <p>Browse available plans or enter a custom recharge amount. Filter by data, validity, or price.</p>
            </div>
            <div class="step-card">
              <div class="step-num">3</div>
              <h4>Make Payment</h4>
              <p>Pay securely via UPI, net banking, debit/credit card, or wallet of your choice.</p>
            </div>
            <div class="step-card">
              <div class="step-num">4</div>
              <h4>Recharge Done!</h4>
              <p>Get instant confirmation via SMS and email. Your balance or plan is activated immediately.</p>
            </div>
          </div>

          <!-- Page CTA -->
          <div class="page-cta">
            <div>
              <h3>Need More Than a Recharge?</h3>
              <p>Pay electricity bills, DTH recharges, FASTag, LPG bookings, and loan EMIs — all from one platform.</p>
            </div>
            <a href="/pages/recharge-bills" class="btn btn-outline">All Services <i class="fas fa-arrow-right"></i></a>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="content-sidebar">
          <!-- Quick Recharge Form -->
          <div class="sidebar-card">
            <h3><i class="fas fa-mobile-screen-button" style="color: var(--primary); margin-right: 6px;"></i> Mobile Recharge</h3>
            <form class="sidebar-form" onsubmit="return false;">
              <div class="form-group">
                <select class="form-input">
                  <option value="">Select Operator</option>
                  <option value="jio">Jio</option>
                  <option value="airtel">Airtel</option>
                  <option value="vi">Vi (Vodafone Idea)</option>
                  <option value="bsnl">BSNL</option>
                  <option value="mtnl">MTNL</option>
                </select>
              </div>
              <div class="form-group">
                <select class="form-input">
                  <option value="">Recharge Type</option>
                  <option value="prepaid">Prepaid</option>
                  <option value="postpaid">Postpaid</option>
                </select>
              </div>
              <div class="form-group">
                <input type="tel" class="form-input" placeholder="Mobile Number" maxlength="10">
              </div>
              <div class="form-group">
                <input type="number" class="form-input" placeholder="Amount (₹)">
              </div>
              <button class="btn btn-primary btn-block" style="width:100%;justify-content:center;">
                Recharge Now <i class="fas fa-arrow-right"></i>
              </button>
            </form>
          </div>

          <!-- Quick Links -->
          <div class="sidebar-card">
            <h3>Other Services</h3>
            <div class="sidebar-links">
              <a href="/pages/electricity-bill"><i class="fas fa-arrow-right"></i> Electricity Bill Payment</a>
              <a href="/pages/dth-recharge"><i class="fas fa-arrow-right"></i> DTH Recharge</a>
              <a href="/pages/fastag-recharge"><i class="fas fa-arrow-right"></i> FASTag Recharge</a>
              <a href="/pages/lpg-gas-booking"><i class="fas fa-arrow-right"></i> LPG Gas Booking</a>
              <a href="/pages/loan-emi-payment"><i class="fas fa-arrow-right"></i> Loan EMI Payment</a>
              <a href="/pages/credit-score"><i class="fas fa-arrow-right"></i> Free Credit Score</a>
              <a href="/pages/personal-loan"><i class="fas fa-arrow-right"></i> Personal Loan</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">FAQs</span>
        <h2>Frequently Asked Questions</h2>
        <p>Find answers to common questions about mobile recharge on TrueCred.</p>
      </div>

      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-question">
            Which mobile operators are supported for recharge?
            <i class="fas fa-chevron-down"></i>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              TrueCred supports all major Indian mobile operators including Reliance Jio, Airtel, Vi (Vodafone Idea), BSNL, and MTNL. Both prepaid recharges and postpaid bill payments are supported across all circles and regions in India.
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            How quickly is my mobile recharge processed?
            <i class="fas fa-chevron-down"></i>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Most mobile recharges are processed instantly — within 5 to 10 seconds of successful payment. Your new plan or talktime balance is activated immediately. In rare cases of operator delays, recharges may take up to 15 minutes.
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            Can I recharge someone else's mobile number?
            <i class="fas fa-chevron-down"></i>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Yes, absolutely. You can recharge any mobile number — whether it's yours, a family member's, or a friend's. Simply enter their 10-digit mobile number, select the operator and plan, and complete the payment. The recharge will be applied to their number directly.
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            What payment methods can I use for mobile recharge?
            <i class="fas fa-chevron-down"></i>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              We accept UPI (Google Pay, PhonePe, Paytm, BHIM), net banking from all major banks, debit cards (Visa, Mastercard, Rupay), credit cards, and popular digital wallets. Choose whichever payment method is most convenient for you.
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            Will I get cashback on mobile recharges?
            <i class="fas fa-chevron-down"></i>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Yes, TrueCred offers up to 5% cashback on mobile recharges, subject to ongoing promotional offers. The cashback is credited to your TrueCred wallet within 24 hours and can be used for future recharges or bill payments. Check the offers section for the latest cashback deals.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->

</BaseLayout>
