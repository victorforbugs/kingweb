<BaseLayout title="FD Calculator — Fixed Deposit Returns | TrueCred Loan Expert">

<section class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="/">Home</a><span class="sep"><i class="fas fa-chevron-right"></i></span><a href="/pages/calculators">Calculators</a><span class="sep"><i class="fas fa-chevron-right"></i></span><span>FD Calculator</span></div>
      <h1>FD Calculator</h1>
      <p class="hero-sub">Calculate your Fixed Deposit maturity amount and interest earned. Compare FD rates from top banks and plan your risk-free investment with guaranteed returns.</p>
      <div class="hero-highlights">
        <div class="highlight-item"><i class="fas fa-lock"></i> <span>Guaranteed Returns</span></div>
        <div class="highlight-item"><i class="fas fa-building-columns"></i> <span>Compare 30+ Banks</span></div>
