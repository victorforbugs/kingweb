---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="LPG Gas Cylinder Booking Online | TrueCred Loan Expert">

<!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span class="sep"><i class="fas fa-chevron-right"></i></span>
        <a href="/pages/recharge-bills">Recharge &amp; Bills</a>
        <span class="sep"><i class="fas fa-chevron-right"></i></span>
        <span>LPG Gas Booking</span>
      </div>
      <h1>LPG Gas Cylinder Booking Online</h1>
      <p class="hero-sub">Book your HP Gas, Bharat Gas, or Indane LPG cylinder refill online in seconds. Pay instantly and get delivery at your doorstep — no calls, no queues.</p>
      <div class="hero-highlights">
        <div class="highlight-item">
          <i class="fas fa-fire-flame-simple"></i> Providers: HP, Bharat, Indane
        </div>
        <div class="highlight-item">
          <i class="fas fa-truck-fast"></i> Delivery: Doorstep
        </div>
        <div class="highlight-item">
          <i class="fas fa-wallet"></i> Pay Online
        </div>
      </div>
    </div>
  </section>

  <!-- Page Content -->
  <section class="page-content">
    <div class="container">
      <div class="content-grid">

        <!-- Main Content -->
        <div class="content-main">
          <h2>Book Your LPG Gas Cylinder Online</h2>
          <p>TrueCred Loan Expert makes LPG gas cylinder booking effortless. Book your refill for HP Gas (Hindustan Petroleum), Bharat Gas (Bharat Petroleum), or Indane Gas (Indian Oil) directly from our platform. No need to call the distributor or visit the gas agency — just enter your details and your booking is confirmed instantly.</p>
          <p>Pay for your cylinder online using UPI, debit card, credit card, or net banking. Once booked, your cylinder will be delivered to your registered address as per the distributor's schedule. You'll also receive an estimated delivery date via SMS confirmation.</p>

          <!-- LPG Providers Comparison -->
          <h3>LPG Gas Providers &amp; Cylinder Prices</h3>
          <div class="table-responsive" style="overflow-x:auto; margin: 24px 0 40px;">
            <table style="width:100%; border-collapse:collapse; min-width:600px;">
              <thead>
                <tr style="background: var(--primary); color: #fff;">
                  <th style="padding: 12px 16px; text-align:left;">Provider</th>
                  <th style="padding: 12px 16px; text-align:left;">Parent Company</th>
                  <th style="padding: 12px 16px; text-align:center;">14.2 kg (Domestic)</th>
                  <th style="padding: 12px 16px; text-align:center;">19 kg (Commercial)</th>
                  <th style="padding: 12px 16px; text-align:center;">5 kg (FTL)</th>
                </tr>
              </thead>
              <tbody>
                <tr style="border-bottom: 1px solid #e5e7eb;">
                  <td style="padding: 12px 16px; font-weight:600;">HP Gas</td>
                  <td style="padding: 12px 16px;">Hindustan Petroleum (HPCL)</td>
                  <td style="padding: 12px 16px; text-align:center; font-weight:700; color: var(--primary);">₹803</td>
                  <td style="padding: 12px 16px; text-align:center;">₹1,865</td>
                  <td style="padding: 12px 16px; text-align:center;">₹502</td>
                </tr>
                <tr style="border-bottom: 1px solid #e5e7eb; background: #f9fafb;">
                  <td style="padding: 12px 16px; font-weight:600;">Bharat Gas</td>
                  <td style="padding: 12px 16px;">Bharat Petroleum (BPCL)</td>
                  <td style="padding: 12px 16px; text-align:center; font-weight:700; color: var(--primary);">₹803</td>
                  <td style="padding: 12px 16px; text-align:center;">₹1,865</td>
                  <td style="padding: 12px 16px; text-align:center;">₹502</td>
                </tr>
                <tr>
                  <td style="padding: 12px 16px; font-weight:600;">Indane Gas</td>
                  <td style="padding: 12px 16px;">Indian Oil Corporation (IOCL)</td>
                  <td style="padding: 12px 16px; text-align:center; font-weight:700; color: var(--primary);">₹803</td>
                  <td style="padding: 12px 16px; text-align:center;">₹1,865</td>
                  <td style="padding: 12px 16px; text-align:center;">₹502</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p style="color:#6b7280; font-size: 0.9rem;">* Prices shown are indicative and may vary by city. Subsidized rates apply for Ujjwala scheme beneficiaries.</p>

          <!-- Benefits -->
          <h2>Why Book LPG Through TrueCred?</h2>
          <ul class="feature-list">
            <li><i class="fas fa-check-circle"></i> <strong>All 3 Providers Supported:</strong> Book refills for HP Gas, Bharat Gas, and Indane Gas — all from one platform</li>
            <li><i class="fas fa-check-circle"></i> <strong>No Calls Needed:</strong> Skip the phone call to your distributor — book online in under 30 seconds</li>
            <li><i class="fas fa-check-circle"></i> <strong>Pay Online Instantly:</strong> Pay via UPI, debit/credit card, or net banking — no cash on delivery hassle</li>
            <li><i class="fas fa-check-circle"></i> <strong>Delivery Tracking:</strong> Get estimated delivery date via SMS and track your booking status</li>
            <li><i class="fas fa-check-circle"></i> <strong>Subsidy Information:</strong> View your subsidy status and amount credited to your bank account</li>
            <li><i class="fas fa-check-circle"></i> <strong>Booking History:</strong> Track all past bookings and refill intervals for better planning</li>
          </ul>

          <!-- How It Works -->
          <h2>How to Book Your LPG Cylinder</h2>
          <p>Book a gas cylinder refill in 4 simple steps.</p>
          <div class="steps-grid">
            <div class="step-card">
              <div class="step-num">1</div>
              <h4>Select Gas Provider</h4>
              <p>Choose your LPG provider — HP Gas, Bharat Gas, or Indane Gas.</p>
            </div>
            <div class="step-card">
              <div class="step-num">2</div>
              <h4>Enter Consumer Number</h4>
              <p>Enter your LPG consumer number or registered mobile number linked to your connection.</p>
            </div>
            <div class="step-card">
              <div class="step-num">3</div>
              <h4>Confirm &amp; Pay</h4>
              <p>Verify your details and cylinder type, then pay online via your preferred method.</p>
            </div>
            <div class="step-card">
              <div class="step-num">4</div>
              <h4>Delivery Scheduled</h4>
              <p>Your cylinder is booked. Receive estimated delivery date and tracking via SMS.</p>
            </div>
          </div>

          <!-- Page CTA -->
          <div class="page-cta">
            <div>
              <h3>Pay All Utility Bills in One Place</h3>
              <p>Electricity, mobile recharge, DTH, FASTag, loan EMIs — manage everything from TrueCred.</p>
            </div>
            <a href="/pages/recharge-bills" class="btn btn-outline">All Services <i class="fas fa-arrow-right"></i></a>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="content-sidebar">
          <!-- LPG Booking Form -->
          <div class="sidebar-card">
            <h3><i class="fas fa-fire-flame-simple" style="color: var(--primary); margin-right: 6px;"></i> Book LPG Cylinder</h3>
            <form class="sidebar-form" onsubmit="return false;">
              <div class="form-group">
                <select class="form-input">
                  <option value="">Select Gas Provider</option>
                  <option value="hp">HP Gas (HPCL)</option>
                  <option value="bharat">Bharat Gas (BPCL)</option>
                  <option value="indane">Indane Gas (IOCL)</option>
                </select>
              </div>
              <div class="form-group">
                <input type="text" class="form-input" placeholder="LPG Consumer Number">
              </div>
              <div class="form-group">
                <input type="tel" class="form-input" placeholder="Registered Mobile Number" maxlength="10">
              </div>
              <div class="form-group">
                <select class="form-input">
                  <option value="">Select Cylinder Type</option>
                  <option value="14.2">14.2 kg (Domestic)</option>
                  <option value="19">19 kg (Commercial)</option>
                  <option value="5">5 kg (FTL)</option>
                </select>
              </div>
              <button class="btn btn-primary btn-block" style="width:100%;justify-content:center;">
                Book Cylinder <i class="fas fa-arrow-right"></i>
              </button>
            </form>
          </div>

          <!-- Quick Links -->
          <div class="sidebar-card">
            <h3>Other Services</h3>
            <div class="sidebar-links">
              <a href="/pages/mobile-recharge"><i class="fas fa-arrow-right"></i> Mobile Recharge</a>
              <a href="/pages/electricity-bill"><i class="fas fa-arrow-right"></i> Electricity Bill Payment</a>
              <a href="/pages/dth-recharge"><i class="fas fa-arrow-right"></i> DTH Recharge</a>
              <a href="/pages/fastag-recharge"><i class="fas fa-arrow-right"></i> FASTag Recharge</a>
              <a href="/pages/loan-emi-payment"><i class="fas fa-arrow-right"></i> Loan EMI Payment</a>
              <a href="/pages/credit-score"><i class="fas fa-arrow-right"></i> Free Credit Score</a>
              <a href="/pages/personal-loan"><i class="fas fa-arrow-right"></i> Personal Loan</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">FAQs</span>
        <h2>Frequently Asked Questions</h2>
        <p>Common questions about LPG gas cylinder booking on TrueCred.</p>
      </div>

      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-question">
            Which LPG gas providers are supported?
            <i class="fas fa-chevron-down"></i>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              TrueCred supports all three major LPG gas providers in India: HP Gas (Hindustan Petroleum Corporation Limited), Bharat Gas (Bharat Petroleum Corporation Limited), and Indane Gas (Indian Oil Corporation Limited). You can book domestic, commercial, and FTL (5 kg) cylinders for any of these providers.
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            How do I find my LPG consumer number?
            <i class="fas fa-chevron-down"></i>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Your LPG consumer number is a unique 17-digit number printed on your gas passbook, subscription voucher, or previous delivery receipts. You can also find it by contacting your local distributor or checking your provider's mobile app. On TrueCred, you can also look up your account using your registered mobile number.
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            How long does delivery take after booking?
            <i class="fas fa-chevron-down"></i>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              After a successful booking, your LPG cylinder is typically delivered within 3-7 days depending on your location and distributor availability. In urban areas, deliveries often happen within 2-3 days. You'll receive an estimated delivery date via SMS immediately after booking, and a delivery confirmation when the cylinder is dispatched.
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            Will I receive my LPG subsidy if I book online?
            <i class="fas fa-chevron-down"></i>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Yes, booking through TrueCred does not affect your LPG subsidy eligibility. The government subsidy (if applicable under PAHAL/DBTL scheme) will continue to be credited directly to your Aadhaar-linked bank account as usual. Your subsidy status and amount can also be tracked on our platform.
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            Can I book more than one cylinder at a time?
            <i class="fas fa-chevron-down"></i>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              For domestic connections, you can book one cylinder refill at a time as per government regulations. The minimum gap between two bookings is typically 15-21 days. For commercial connections, multiple cylinder bookings may be possible depending on your distributor's policy. Contact your local distributor for bulk commercial orders.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->

</BaseLayout>
