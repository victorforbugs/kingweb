            </thead>
            <tbody>
              <tr>
                <td>SBI</td>
                <td>8.50% onwards</td>
                <td>Up to 0.35%</td>
                <td>30 Years</td>
              </tr>
              <tr>
                <td>HDFC Ltd</td>
                <td>8.60% onwards</td>
                <td>Up to 0.50%</td>
                <td>30 Years</td>
              </tr>
              <tr>
                <td>ICICI Bank</td>
                <td>8.65% onwards</td>
                <td>Up to 1.00%</td>
                <td>25 Years</td>
              </tr>
              <tr>
                <td>Axis Bank</td>
