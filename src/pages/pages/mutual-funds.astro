                <tr><td><strong>Large Cap Funds</strong></td><td>Moderate</td><td>12%–14%</td><td>5+ years</td><td>Stable equity growth</td></tr>
                <tr><td><strong>Mid Cap Funds</strong></td><td>Moderate-High</td><td>15%–18%</td><td>5–7 years</td><td>Higher growth potential</td></tr>
                <tr><td><strong>Small Cap Funds</strong></td><td>High</td><td>18%–25%</td><td>7+ years</td><td>Aggressive wealth creation</td></tr>
                <tr><td><strong>ELSS (Tax Saving)</strong></td><td>Moderate-High</td><td>13%–16%</td><td>3+ years</td><td>Tax saving under 80C</td></tr>
