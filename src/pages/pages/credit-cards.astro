                  <option value="salaried">Salaried</option>
                  <option value="self-employed">Self Employed</option>
                  <option value="business">Business Owner</option>
                  <option value="student">Student</option>
                  <option value="freelancer">Freelancer</option>
                </select>
              </div>
              <div class="form-group">
                <select class="form-input">
                  <option value="" disabled selected>Monthly Income</option>
                  <option value="below-15k">Below ₹15,000</option>
                  <option value="15k-25k">₹15,000 - ₹25,000</option>
                  <option value="25k-50k">₹25,000 - ₹50,000</option>
                  <option value="50k-1l">₹50,000 - ₹1,00,000</option>
                  <option value="above-1l">Above ₹1,00,000</option>
                </select>
              </div>
              <div class="form-group">
                <select class="form-input">
                  <option value="" disabled selected>Credit Score Range</option>
                  <option value="below-600">Below 600</option>
                  <option value="600-700">600 - 700</option>
                  <option value="700-750">700 - 750</option>
                  <option value="750-800">750 - 800</option>
                  <option value="above-800">Above 800</option>
                </select>
              </div>
              <button type="button" class="btn btn-primary btn-block">
                <i class="fas fa-search"></i> Find Cards
              </button>
            </form>
          </div>

          <!-- Quick Links -->
          <div class="sidebar-card">
            <h3>Quick Links</h3>
            <div class="sidebar-links">
              <a href="#"><i class="fas fa-arrow-right"></i> Best Credit Cards 2026</a>
              <a href="#"><i class="fas fa-arrow-right"></i> Lifetime Free Cards</a>
              <a href="#"><i class="fas fa-arrow-right"></i> Rewards Credit Cards</a>
              <a href="#"><i class="fas fa-arrow-right"></i> Cashback Credit Cards</a>
              <a href="#"><i class="fas fa-arrow-right"></i> Travel Credit Cards</a>
              <a href="#"><i class="fas fa-arrow-right"></i> Fuel Credit Cards</a>
              <a href="#"><i class="fas fa-arrow-right"></i> Credit Card Eligibility</a>
              <a href="#"><i class="fas fa-arrow-right"></i> Compare Credit Cards</a>
