            </div>
            <div class="step-card">
              <div class="step-num">3</div>
              <h4>Submit Application</h4>
              <p>Fill in the online form with your KYC and income documents</p>
            </div>
            <div class="step-card">
              <div class="step-num">4</div>
              <h4>Get Your Card</h4>
              <p>Receive instant approval and get your card delivered to your doorstep</p>
            </div>
          </div>

        </div>

        <!-- Sidebar -->
        <div class="content-sidebar">

          <!-- Find Best Card Form -->
          <div class="sidebar-card">
            <h3><i class="fas fa-search" style="color: var(--primary); margin-right: 8px;"></i> Find Best Card</h3>
