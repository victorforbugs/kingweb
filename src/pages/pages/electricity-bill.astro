---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Electricity Bill Payment Online | TrueCred Loan Expert">

<!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span class="sep"><i class="fas fa-chevron-right"></i></span>
        <a href="/pages/recharge-bills">Recharge &amp; Bills</a>
        <span class="sep"><i class="fas fa-chevron-right"></i></span>
        <span>Electricity Bill Payment</span>
      </div>
      <h1>Electricity Bill Payment Online</h1>
      <p class="hero-sub">Pay your electricity bill online for any state electricity board or private distributor. Instant confirmation, zero convenience fee, and auto-pay support.</p>
      <div class="hero-highlights">
        <div class="highlight-item">
          <i class="fas fa-building-columns"></i> Boards: All States
        </div>
        <div class="highlight-item">
          <i class="fas fa-receipt"></i> Confirmation: Instant
        </div>
        <div class="highlight-item">
          <i class="fas fa-hand-holding-dollar"></i> Convenience Fee: ₹0
        </div>
      </div>
    </div>
  </section>

  <!-- Page Content -->
  <section class="page-content">
    <div class="container">
      <div class="content-grid">

        <!-- Main Content -->
        <div class="content-main">
          <h2>Pay Electricity Bills Hassle-Free</h2>
          <p>TrueCred Loan Expert lets you pay your electricity bills online for all state electricity boards and private power distributors across India. No more standing in long queues or worrying about missed due dates — pay your bill in just a few clicks and receive instant confirmation.</p>
          <p>Our platform auto-fetches your outstanding bill amount using your consumer number, so there's no chance of errors. Set up auto-pay to ensure your bills are paid automatically before the due date every month.</p>

          <!-- Supported Boards Table -->
          <h3>Supported Electricity Boards</h3>
          <div class="table-responsive" style="overflow-x:auto; margin: 24px 0 40px;">
            <table style="width:100%; border-collapse:collapse; min-width:600px;">
              <thead>
                <tr style="background: var(--primary); color: #fff;">
                  <th style="padding: 12px 16px; text-align:left;">State</th>
                  <th style="padding: 12px 16px; text-align:left;">Electricity Board</th>
                  <th style="padding: 12px 16px; text-align:center;">Auto-Fetch Bill</th>
                  <th style="padding: 12px 16px; text-align:center;">Auto-Pay</th>
                </tr>
              </thead>
              <tbody>
                <tr style="border-bottom: 1px solid #e5e7eb;">
                  <td style="padding: 12px 16px; font-weight:600;">Maharashtra</td>
                  <td style="padding: 12px 16px;">MSEDCL / Adani / Tata Power</td>
                  <td style="padding: 12px 16px; text-align:center; color: green;"><i class="fas fa-check"></i> Yes</td>
                  <td style="padding: 12px 16px; text-align:center; color: green;"><i class="fas fa-check"></i> Yes</td>
                </tr>
                <tr style="border-bottom: 1px solid #e5e7eb; background: #f9fafb;">
                  <td style="padding: 12px 16px; font-weight:600;">Delhi</td>
                  <td style="padding: 12px 16px;">BSES Rajdhani / BSES Yamuna / Tata Power DDL</td>
                  <td style="padding: 12px 16px; text-align:center; color: green;"><i class="fas fa-check"></i> Yes</td>
                  <td style="padding: 12px 16px; text-align:center; color: green;"><i class="fas fa-check"></i> Yes</td>
                </tr>
                <tr style="border-bottom: 1px solid #e5e7eb;">
                  <td style="padding: 12px 16px; font-weight:600;">Karnataka</td>
                  <td style="padding: 12px 16px;">BESCOM / MESCOM / HESCOM / GESCOM / CESC</td>
                  <td style="padding: 12px 16px; text-align:center; color: green;"><i class="fas fa-check"></i> Yes</td>
                  <td style="padding: 12px 16px; text-align:center; color: green;"><i class="fas fa-check"></i> Yes</td>
                </tr>
                <tr style="border-bottom: 1px solid #e5e7eb; background: #f9fafb;">
                  <td style="padding: 12px 16px; font-weight:600;">Tamil Nadu</td>
                  <td style="padding: 12px 16px;">TANGEDCO</td>
                  <td style="padding: 12px 16px; text-align:center; color: green;"><i class="fas fa-check"></i> Yes</td>
                  <td style="padding: 12px 16px; text-align:center; color: green;"><i class="fas fa-check"></i> Yes</td>
                </tr>
                <tr style="border-bottom: 1px solid #e5e7eb;">
                  <td style="padding: 12px 16px; font-weight:600;">Uttar Pradesh</td>
                  <td style="padding: 12px 16px;">UPPCL / DVVNL / PVVNL / MVVNL / PuVVNL</td>
                  <td style="padding: 12px 16px; text-align:center; color: green;"><i class="fas fa-check"></i> Yes</td>
                  <td style="padding: 12px 16px; text-align:center; color: green;"><i class="fas fa-check"></i> Yes</td>
                </tr>
                <tr>
                  <td style="padding: 12px 16px; font-weight:600;">Gujarat</td>
                  <td style="padding: 12px 16px;">DGVCL / MGVCL / PGVCL / UGVCL / Torrent Power</td>
                  <td style="padding: 12px 16px; text-align:center; color: green;"><i class="fas fa-check"></i> Yes</td>
                  <td style="padding: 12px 16px; text-align:center; color: green;"><i class="fas fa-check"></i> Yes</td>
                </tr>
              </tbody>
            </table>
          </div>
          <p style="color:#6b7280; font-size: 0.9rem;">* All state electricity boards across India are supported. The table above shows select popular boards.</p>

          <!-- Benefits -->
          <h2>Why Pay Electricity Bills on TrueCred?</h2>
          <ul class="feature-list">
            <li><i class="fas fa-check-circle"></i> <strong>All State Boards Covered:</strong> Pay bills for any electricity distributor across all 28 states and 8 UTs of India</li>
            <li><i class="fas fa-check-circle"></i> <strong>Zero Convenience Fee:</strong> No extra charges — you pay only your actual bill amount with no hidden fees</li>
            <li><i class="fas fa-check-circle"></i> <strong>Auto-Fetch Bill Amount:</strong> Enter your consumer number and we fetch your outstanding bill automatically</li>
            <li><i class="fas fa-check-circle"></i> <strong>Auto-Pay Setup:</strong> Never miss a due date again — set up auto-pay via UPI mandate or e-NACH</li>
            <li><i class="fas fa-check-circle"></i> <strong>Instant Payment Confirmation:</strong> Get real-time payment receipt via SMS and email for your records</li>
            <li><i class="fas fa-check-circle"></i> <strong>Payment History &amp; Tracking:</strong> View complete bill payment history and download receipts anytime</li>
          </ul>

          <!-- How It Works -->
          <h2>How to Pay Your Electricity Bill</h2>
          <p>Complete your electricity bill payment in 4 easy steps.</p>
          <div class="steps-grid">
            <div class="step-card">
              <div class="step-num">1</div>
              <h4>Select Your Board</h4>
              <p>Choose your state and electricity board or distribution company from the dropdown.</p>
            </div>
            <div class="step-card">
              <div class="step-num">2</div>
              <h4>Enter Consumer Number</h4>
              <p>Type your consumer number or account ID as printed on your electricity bill.</p>
            </div>
            <div class="step-card">
              <div class="step-num">3</div>
              <h4>Verify &amp; Pay</h4>
              <p>Review the auto-fetched bill amount and pay via UPI, card, net banking, or wallet.</p>
            </div>
            <div class="step-card">
              <div class="step-num">4</div>
              <h4>Get Receipt</h4>
              <p>Receive instant payment confirmation and downloadable receipt via SMS and email.</p>
            </div>
          </div>

          <!-- Page CTA -->
          <div class="page-cta">
            <div>
              <h3>Pay All Your Bills in One Place</h3>
              <p>Mobile recharge, DTH, FASTag, LPG booking, and loan EMIs — manage everything from TrueCred.</p>
            </div>
            <a href="/pages/recharge-bills" class="btn btn-outline">All Services <i class="fas fa-arrow-right"></i></a>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="content-sidebar">
          <!-- Bill Payment Form -->
          <div class="sidebar-card">
            <h3><i class="fas fa-bolt" style="color: var(--primary); margin-right: 6px;"></i> Pay Electricity Bill</h3>
            <form class="sidebar-form" onsubmit="return false;">
              <div class="form-group">
                <select class="form-input">
                  <option value="">Select State</option>
                  <option value="maharashtra">Maharashtra</option>
                  <option value="delhi">Delhi</option>
                  <option value="karnataka">Karnataka</option>
                  <option value="tamilnadu">Tamil Nadu</option>
                  <option value="up">Uttar Pradesh</option>
                  <option value="gujarat">Gujarat</option>
                  <option value="rajasthan">Rajasthan</option>
                  <option value="westbengal">West Bengal</option>
                  <option value="other">Other States</option>
                </select>
              </div>
              <div class="form-group">
                <select class="form-input">
                  <option value="">Select Electricity Board</option>
                  <option value="msedcl">MSEDCL</option>
                  <option value="tatapower">Tata Power</option>
                  <option value="adani">Adani Electricity</option>
                  <option value="bses">BSES</option>
                  <option value="bescom">BESCOM</option>
                </select>
              </div>
              <div class="form-group">
                <input type="text" class="form-input" placeholder="Consumer Number / Account ID">
              </div>
              <div class="form-group">
                <input type="number" class="form-input" placeholder="Bill Amount (₹)">
              </div>
              <button class="btn btn-primary btn-block" style="width:100%;justify-content:center;">
                Pay Bill Now <i class="fas fa-arrow-right"></i>
              </button>
            </form>
          </div>

          <!-- Quick Links -->
          <div class="sidebar-card">
            <h3>Other Services</h3>
            <div class="sidebar-links">
              <a href="/pages/mobile-recharge"><i class="fas fa-arrow-right"></i> Mobile Recharge</a>
              <a href="/pages/dth-recharge"><i class="fas fa-arrow-right"></i> DTH Recharge</a>
              <a href="/pages/fastag-recharge"><i class="fas fa-arrow-right"></i> FASTag Recharge</a>
              <a href="/pages/lpg-gas-booking"><i class="fas fa-arrow-right"></i> LPG Gas Booking</a>
              <a href="/pages/loan-emi-payment"><i class="fas fa-arrow-right"></i> Loan EMI Payment</a>
              <a href="/pages/credit-score"><i class="fas fa-arrow-right"></i> Free Credit Score</a>
              <a href="/pages/personal-loan"><i class="fas fa-arrow-right"></i> Personal Loan</a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">FAQs</span>
        <h2>Frequently Asked Questions</h2>
        <p>Common questions about electricity bill payments on TrueCred.</p>
      </div>

      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-question">
            Which electricity boards are supported?
            <i class="fas fa-chevron-down"></i>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              TrueCred supports all state electricity boards and private power distributors across India — including MSEDCL, Tata Power, Adani Electricity, BSES, BESCOM, TANGEDCO, UPPCL, DGVCL, Torrent Power, and many more. If your board is listed in your region, you can pay through our platform.
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            Is there a convenience fee for paying electricity bills?
            <i class="fas fa-chevron-down"></i>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              No, TrueCred does not charge any convenience fee for electricity bill payments. You pay only the actual bill amount as generated by your electricity board. There are no hidden charges or processing fees.
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            How do I find my consumer number?
            <i class="fas fa-chevron-down"></i>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Your consumer number (also called account number, CA number, or service connection number) is printed on your electricity bill. It is usually a 10-12 digit number found at the top of the bill. You can also find it in previous payment receipts or by contacting your electricity board.
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            Can I set up auto-pay for my electricity bill?
            <i class="fas fa-chevron-down"></i>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Yes, TrueCred supports auto-pay for electricity bills via UPI mandate or e-NACH. Once set up, your bill will be automatically paid 2-3 days before the due date. You'll receive a notification before each auto-debit, and you can cancel auto-pay anytime from your account settings.
            </div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-question">
            What if my electricity bill payment fails?
            <i class="fas fa-chevron-down"></i>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              If your payment fails but money has been debited, it will be automatically refunded within 5-7 business days to your original payment method. You can also retry the payment. If you face persistent issues, contact our support team with your transaction ID for immediate assistance.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->

</BaseLayout>
